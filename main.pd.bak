		<object type="DiagramEntitySetting" id="836">
		    <field name="entity">
			<object type="Scenario" id="837">
			    <base type="Entity">
				<field name="name">Gestionar Feedback scenario</field>
				<field name="description">Després d’una setmana d’haver fet una compra, es demana a l’usuari la seva opinió sobre el/s producte/s que ha comprat. El sistema registra la valoració i millora el sistema de suggeriments per a l’usuari.</field>
