				    <field name="connectTo"><list>
					<object type="Actor" id="6">
					    <base type="Entity">
						<field name="name">Usuari</field>
						<field name="description">És l’actor principal de compra i delega les seves tasques a l’agent assistent virtual. S’encarrega d’imposar les seves restriccions de cerca de productes, fer peticions de compra i/o devolució i proporcionar feedback sobre els productes comprats.</field>
						<field name="uniqueId">421</field>
