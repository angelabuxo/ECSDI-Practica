																																							    <object type="Goal" id="68">
																																								<base type="Entity">
																																								    <field name="name">Processar petició devolució</field>
																																								    <field name="description">El sistema ha de processar la petició de devolució de l’usuari comprovant que tots els camps siguin correctes.</field>
																																								    <field name="uniqueId">389</field>
																																								</base>

																																								<field name="scope">:optional</field>
																																							    </object>

																																							    <object type="Goal" id="69">
																																								<base type="Entity">
																																								    <field name="name">Denegar devolució</field>
																																								    <field name="description">El sistema ha d’informar l’usuari sobre l’estat denegat de la seva sol·licitud de devolució, aportant informació sobre el motiu pel qual s’ha denegat la devolució.</field>
																																								    <field name="uniqueId">390</field>
																																								</base>

																																								<field name="scope">:optional</field>
																																							    </object>

																																							    <object type="Goal" id="70">
																																								<base type="Entity">
																																								    <field name="name">Acceptar devolució</field>
																																								    <field name="description"> = processar devolució</field>
																																								    <field name="uniqueId">322</field>
																																								</base>

																																								<field name="subGoals"><list>
																																								    <object type="Goal" id="71">
																																									<base type="Entity">
																																									    <field name="name">Recollir producte retornat</field>
																																									    <field name="description">El sistema ha de registrar que el producte retornat ha estat rebut correctament per tal de continuar amb el procés de devolució i  ha d’establir comunicació amb la botiga o servei extern encarregat de gestionar el retorn per coordinar el procés.</field>
																																									    <field name="uniqueId">391</field>
																																									</base>

																																									<field name="scope">:optional</field>
																																								    </object>

																																								    <object type="Goal" id="72">
																																									<base type="Entity">
																																									    <field name="name">Retornar diners</field>
																																									    <field name="description">Un cop confirmada la recepció del producte retornat, el sistema ha de processar el reemborsament corresponent a l’usuari segons la forma de pagament utilitzada.</field>
																																									    <field name="uniqueId">392</field>
																																									</base>

