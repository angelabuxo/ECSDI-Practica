																															<field name="roles"><list>
																															    <object type="Role" id="173">
																																<base type="Entity">
																																    <field name="name">Negociador d'enviament</field>
																																    <field name="description">Aquest rol s’encarrega de dur a terme la negociació amb els transportistes, proposant l’enviament d’un cert nombre de paquets (per pes) a una ciutat destí i amb un termini màxim d’entrega. Un cop els diferents transportistes responen amb les propostes, el negociador escull el més adeqüat. La percepció d’aquest rol és el transcurs d’un cert temps determinat, cada 3 hores. L’objectiu associat és la gestió de la negociació de l’enviament dels lots, i com a resultat, l’acció d’haver escollit un transportista.</field>
																																    <field name="uniqueId">406</field>
																																</base>

																																<field name="goals"><list>
																																    <object ref="143"/>
																																    </list>
																																</field>
