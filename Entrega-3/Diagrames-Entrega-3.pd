				<field name="name">Comprar productes</field>
				<field name="description">Objectiu on es descriu que l’usuari ha de poder comprar un o diversos productes que ha seleccionat prèviament. Quan l’usuari fa la petició de compra, el sistema li demana les seves preferències d’enviament i les dades de pagament. Quan aquestes dades es validen, el sistema verifica la disponibilitat dels productes i valida la transacció. Dins d’aquest objectiu es gestionen també els processos d’enviament i pagament dels productes. </field>
				<field name="uniqueId">294</field>
			    </base>

			    <field name="subGoals"><list>
				<object ref="449"/>

				<object ref="477"/>

				<object ref="459"/>
				</list>
			    </field>
			    <field name="scope">:optional</field>
			</object>
		    </field>
