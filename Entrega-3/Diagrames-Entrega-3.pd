																																																																															    <object type="Goal" id="151">
																																																																																<base type="Entity">
																																																																																    <field name="name">Validar devolució</field>
																																																																																    <field name="description">El sistema ha de verificar que la devolució compleixi les condicions de la 	política de devolucions. Un cop comprovada la validesa, el sistema ha de determinar si la sol·licitud de devolució és acceptada o rebutjada segons les condicions definides.</field>
																																																																																    <field name="uniqueId">319</field>
																																																																																</base>

