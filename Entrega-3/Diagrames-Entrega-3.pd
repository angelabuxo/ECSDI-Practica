																																																																						    <object type="Capability" id="142">
																																																																							<base type="Entity">
																																																																							    <field name="name">Cp. Retornar diners devolució</field>
																																																																							    <field name="description">En tercer cas, la capacitat Gestionar Devolucions es basa en un sol pla.
Pla retornar diners (pla_retornar_diners). S'activa en rebre PeticioRetornDiners de l'Agent Retornador. Confirma el reemborsament del lot per ACL (ConfirmacioRetornDiners) sense escriure a devolucions.ttl. En cas de producte extern pot consultar dades bancàries del venedor.</field>
																																																																							    <field name="uniqueId">831</field>
																																																																							</base>

																																																																							<field name="processes"></field>
																																																																							<field name="notes"></field>
																																																																							<field name="includedPlans"><list>
																																																																							    <object type="Plan" id="143">
																																																																								<base type="Entity">
																																																																								    <field name="name">Pla retornar diners</field>
																																																																								    <field name="description">Confirma automàticament el reemborsament d'un lot (ConfirmacioRetornDiners). No persisteix a devolucions.ttl: l'escriptura la fa el Retornador al pla de compliment després de rebre la confirmació.</field>
																																																																								    <field name="uniqueId">858</field>
																																																																								</base>

