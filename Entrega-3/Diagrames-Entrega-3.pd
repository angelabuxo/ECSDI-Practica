															<field name="agentsResponding"><list>
															    <object type="Agent" id="19">
																<base type="Entity">
																    <field name="name">Ag. Venedor Extern</field>
																    <field name="description">Agent encarregat de comunicar-se amb els venedors externs per tal d'introduïr els seus productes al catàleg i gestionar les compres dels seus productes. Efectua el rol de Gestor venedors externs.</field>
																    <field name="uniqueId">457</field>
