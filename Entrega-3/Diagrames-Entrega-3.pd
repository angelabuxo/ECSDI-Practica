																																																																																		    <field name="description">Un cop acceptada la devolució per política, el sistema ha de processar el reemborsament corresponent a l'usuari (per lot i venedor extern si cal) mitjançant el Cobrador.</field>
																																																																																		    <field name="uniqueId">392</field>
																																																																																		</base>

