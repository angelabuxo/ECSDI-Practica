												    <field name="connectTo"><list>
													<object type="Actor" id="17">
													    <base type="Entity">
														<field name="name">Venedor extern</field>
														<field name="description">Representa les empreses o venedors externs que anuncien els seus productes a la plataforma. Interactua amb el sistema mitjançant el seu agent representant, informant periòdicament de l’estoc dels seus productes.</field>
