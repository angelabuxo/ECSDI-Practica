																																																																												    </object>

																																																																												    <object type="Role" id="317">
																																																																													<base type="Entity">
																																																																													    <field name="name">Gestor de devolucions</field>
																																																																													    <field name="description">Aquest rol coordina el reemborsament un cop acceptada la devolució per política: invoca el Cobrador per lot i comunica a l'usuari l'import reemborsat (acceptació parcial o total). El pla de compliment del Retornador és l'únic que escriu a devolucions.ttl (registre per lot i resum agregat).</field>
