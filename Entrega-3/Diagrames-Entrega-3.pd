																																																																											    </list>
																																																																											</field>
																																																																											<field name="fromEntities"><list>
																																																																											    <object type="Agent" id="147">
																																																																												<base type="Entity">
																																																																												    <field name="name">Ag. Retornador</field>
																																																																												    <field name="description">Agent que gestiona les sol·licituds de devolució: validació de política (motius i terminis) via l'Opinador, reemborsament coordinat amb el Cobrador i resposta a l'usuari (interfície web /iface o ACL). És l'únic agent que escriu a devolucions.ttl. Efectua els rols de Validador de devolucions i Gestor de devolucions. La logística física del retorn del paquet queda fora de l'abast implementat en aquesta fase.</field>
																																																																												    <field name="uniqueId">451</field>
																																																																												</base>

