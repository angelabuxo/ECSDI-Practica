																																																																																	<base type="Entity">
																																																																																	    <field name="name">Acceptar devolució</field>
																																																																																	    <field name="description">El sistema ha de gestionar la sol·licitud realitzada per l’usuari per dur a terme el procés de devolució.</field>
																																																																																	    <field name="uniqueId">322</field>
																																																																																	</base>

																																																																																	<field name="subGoals"><list>
