																																																																														    <object type="Plan" id="150">
																																																																															<base type="Entity">
																																																																															    <field name="name">Pla de compliment de devolució</field>
																																																																															    <field name="description">Construeix la petició a partir dels productes seleccionats. Per a cada comanda afectada consulta l'Opinador (PeticioDevolucio / ResolucioDevolucio). Agrega la decisió global. Si es denega, respon a l'usuari. Si s'accepta (total o parcialment), activa pla_retorn per a cada lot vàlid, registra cada lot confirmat i el resum agregat a devolucions.ttl, i comunica acceptació amb import reemborsat.</field>
																																																																															    <field name="uniqueId">868</field>
																																																																															</base>

