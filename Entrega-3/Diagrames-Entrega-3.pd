																																																																									<field name="type">
																																																																									    <object type="Message" id="145">
																																																																										<base type="Interaction">
																																																																										    <base type="Entity">
																																																																											<field name="name">Fer cobrament d'una devolució</field>
																																																																											<field name="description">PeticioRetornDiners del Retornador al Cobrador per a un lot de reemborsament (import, comanda, productes i venedor extern si cal).</field>
