																												<field name="goals"><list>
																												    <object type="Goal" id="564">
																													<base type="Entity">
																													    <field name="name">Buscar productes</field>
																													    <field name="description">Objectiu on es descriu que s’ha de poder cercar un o diversos productes dins del sistema mitjançant uns paràmetres determinats i obtenir la informació detallada dels resultats trobats.</field>
																													    <field name="uniqueId">329</field>
																													</base>

																													<field name="subGoals"><list>
																													    <object type="Goal" id="565">
																														<base type="Entity">
																														    <field name="name">Processar petició</field>
																														    <field name="description">El sistema ha de ser capaç de gestionar la petició de cerca realitzada per l’usuari per tal d’interpretar correctament la consulta i iniciar el procés de cerca corresponent.</field>
																														    <field name="uniqueId">291</field>
																														</base>

																														<field name="subGoals"><list>
																														    <object type="Goal" id="566">
																															<base type="Entity">
																															    <field name="name">Rebre dades cerca</field>
																															    <field name="description">El sistema ha de rebre els paràmetres introduïts per l’usuari, com la marca, model, rang de preu… per tal de poder utilitzar-los en la consulta.
</field>
																															    <field name="uniqueId">292</field>
																															</base>

																														    </object>

																														    <object type="Goal" id="567">
																															<base type="Entity">
																															    <field name="name">Realitzar cerca</field>
																															    <field name="description">Un cop rebudes les dades, el sistema ha d’executar la cerca dins de la base de dades de productes per tal de trobar aquells que coincideixin amb els criteris especificats.</field>
																															    <field name="uniqueId">293</field>
																															</base>

																														    </object>
																														    </list>
																														</field>
																														<field name="scope">:optional</field>
																													    </object>

																													    <object type="Goal" id="568">
																														<base type="Entity">
																														    <field name="name">Mostrar productes</field>
																														    <field name="description">El sistema ha de mostrar a l’usuari els productes trobats com a resultat de la cerca, amb la informació rellevant de cadascun d’ells perquè l’usuari els pugui revisar.</field>
																														    <field name="uniqueId">290</field>
																														</base>

																														<field name="scope">:optional</field>
																													    </object>
																													    </list>
