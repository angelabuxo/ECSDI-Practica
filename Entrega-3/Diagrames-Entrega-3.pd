																																																																														<base type="Interaction">
																																																																														    <base type="Entity">
																																																																															<field name="name">Petició de devolució </field>
																																																																															<field name="description">L'usuari sol·licita la devolució de productes concrets (formulari /iface amb selecció per comanda i motiu, o missatge ACL PeticioDevolucio a /comm).</field>
																																																																															<field name="uniqueId">361</field>
