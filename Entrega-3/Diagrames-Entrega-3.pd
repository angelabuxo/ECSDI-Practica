					<base type="Entity">
					    <field name="name">Mostrar detalls de cerca </field>
					    <field name="uniqueId">376</field>
					    <field name="includeInReport">:false</field>
					    <field name="connectTo"><list>
						<object type="Actor" id="7">
						    <base type="Entity">
							<field name="name">Usuari</field>
							<field name="description">És l’actor principal de compra i delega les seves tasques a l’agent assistent virtual. S’encarrega d’imposar les seves restriccions de cerca de productes, fer peticions de compra i/o devolució i proporcionar feedback sobre els productes comprats.</field>
							<field name="uniqueId">421</field>
							<field name="connectTo"><list>
							    <object type="Percept" id="8">
								<base type="Interaction">
								    <base type="Entity">
									<field name="name">Petició de cercar producte</field>
									<field name="description"></field>
									<field name="uniqueId">357</field>
									<field name="includeInReport">:false</field>
									<field name="connectTo"><list>
									    <object type="Actor" id="9">
										<base type="Entity">
										    <field name="name">Gestor del sistema</field>
										    <field name="description">És l’element central de la plataforma i engloba el control de totes les tasques, coordinant els agents interns que es comuniquen amb els diferents actors externs. S’encarrega d’accions com: mostrar productes, enviar factures, gestionar recomanacions de productes, notificar dades d’enviament als usuaris i gestionar les negociacions amb els transportistes des dels centres logístics.</field>
										    <field name="uniqueId">424</field>
										    <field name="connectTo"><list>
											<object type="Action" id="10">
											    <base type="Interaction">
												<base type="Entity">
												    <field name="name">Acceptació/Negació de devolució</field>
												    <field name="description">Informa l'usuari de l'acceptació, denegació o acceptació parcial de la devolució, amb motiu i import reemborsat si escau.</field>
												    <field name="uniqueId">368</field>
												    <field name="includeInReport">:false</field>
