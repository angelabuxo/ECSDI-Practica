<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/agentzon#"
     xml:base="http://www.semanticweb.org/agentzon"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:azon="http://www.semanticweb.org/agentzon#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/agentzon">
        <rdfs:comment xml:lang="ca">
      Ontologia compartida del sistema AgentZon. Modela actors externs,
      productes, comandes, logística, devolucions, pagaments, suggeriments i les
      comunicacions RDF/FIPA-ACL que connecten tot el sistema distribuït.
    </rdfs:comment>
        <rdfs:label xml:lang="ca">Ontologia AgentZon</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/agentzon#AssignatATransportista -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#AssignatATransportista">
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Transportista"/>
        <rdfs:label xml:lang="ca">assignat a transportista</rdfs:label>
    </owl:ObjectProperty>
    <!-- http://www.semanticweb.org/agentzon#EsRespostaA -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#EsRespostaA">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
        <rdfs:label xml:lang="ca">és resposta a</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/agentzon#GeneraRecomanacio -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#GeneraRecomanacio">
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Recomanacio"/>
        <rdfs:label xml:lang="ca">genera recomanació</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/agentzon#MostraProducte -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#MostraProducte">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#ResultatCerca"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Producte"/>
        <rdfs:comment xml:lang="ca">Relaciona un resultat de cerca amb els productes retornats.</rdfs:comment>
        <rdfs:label xml:lang="ca">mostra producte</rdfs:label>
    </owl:ObjectProperty>
    <!-- http://www.semanticweb.org/agentzon#SobreComanda -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#SobreComanda">
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Comanda"/>
        <rdfs:comment xml:lang="ca">Relaciona una comunicació amb la comanda sobre la qual opera.</rdfs:comment>
        <rdfs:label xml:lang="ca">sobre comanda</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/agentzon#SobreLot -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#SobreLot">
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Lot"/>
        <rdfs:label xml:lang="ca">sobre lot</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/agentzon#SobreProducte -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#SobreProducte">
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Producte"/>
        <rdfs:label xml:lang="ca">sobre producte</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/agentzon#TeDadesBancaries -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#TeDadesBancaries">
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#DadesBancaries"/>
        <rdfs:label xml:lang="ca">té dades bancàries</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/agentzon#TeDadesEnviament -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#TeDadesEnviament">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#Comanda"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#DadesEnviamentUsuari"/>
        <rdfs:label xml:lang="ca">té dades d’enviament</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/agentzon#TeFeedback -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#TeFeedback">
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Feedback"/>
        <rdfs:label xml:lang="ca">té feedback</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/agentzon#TeProducte -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#TeProducte">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#Comanda"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#Lot"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#HistorialCompra"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#PeticioRegistreCompra"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#ProducteLocalitzat"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Producte"/>
        <rdfs:comment xml:lang="ca">Relaciona una comanda, un lot, un historial de compra o una comunicació amb els seus productes.</rdfs:comment>
        <rdfs:label xml:lang="ca">TeProducte</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/agentzon#UbicatACentre -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#UbicatACentre">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#UbicacioProducte"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#CentreLogistic"/>
        <rdfs:label xml:lang="ca">ubicat a centre</rdfs:label>
    </owl:ObjectProperty>
    


