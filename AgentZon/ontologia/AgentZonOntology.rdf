<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:azon="http://www.semanticweb.org/agentzon#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/agentzon">
    <rdfs:label xml:lang="en">AgentZon Phase 2 Ontology</rdfs:label>
    <rdfs:comment xml:lang="en">
      Minimal shared ontology for the Phase 2 distributed prototype:
      search requests/results, simple internal orders, one logistics center,
      transport offers, and purchase-history registration.
    </rdfs:comment>
  </owl:Ontology>

  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Producte"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Comanda"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Lot"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#CentreLogistic"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Transportista"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Usuari"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#DadesEnviamentUsuari"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioCerca"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ResultatCerca"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioRegistreCompra"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ConfirmacioRegistreCompra"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ProducteLocalitzat"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioTransport"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#RespostaOfertaTransport"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#HistorialCompra"/>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#UbicacioProducte"/>

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#mostraProducte">
    <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#ResultatCerca"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Producte"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#teProducte">
    <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#Comanda"/>
    <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#ProducteLocalitzat"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Producte"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#idProducte">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#idComanda">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#idUsuari">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#idLot">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#idTransportista">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#idCentreLogistic">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#nom">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#descripcio">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#categoria">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#marca">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#preu">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#pes">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#ciutat">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#carrer">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#prioritat">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#metodePagament">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#teText">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#teCategoria">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#teMarca">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#preuMinim">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#preuMaxim">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#totalResultats">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#dataEntrega">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#costTransport">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#nomTransportista">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

</rdf:RDF>
