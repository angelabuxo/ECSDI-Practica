<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:acl="http://www.nuin.org/ontology/fipa/acl#"
    xmlns:azon="http://www.semanticweb.org/agentzon#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/agentzon">
    <owl:imports rdf:resource="http://www.nuin.org/ontology/fipa/acl"/>
    <rdfs:label xml:lang="ca">Ontologia AgentZon</rdfs:label>
    <rdfs:comment xml:lang="ca">
      Ontologia compartida del sistema AgentZon. Modela actors externs, dades internes
      de negoci i el contingut semàntic dels missatges. Els actes comunicatius, el
      remitent, el receptor i la referència a l’ontologia es representen amb FIPA-ACL.
    </rdfs:comment>
  </owl:Ontology>

  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Actor">
    <rdfs:label xml:lang="ca">Actor</rdfs:label>
    <rdfs:comment xml:lang="ca">Entitat externa al sistema que participa en processos de negoci.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Usuari">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Actor"/>
    <rdfs:label xml:lang="ca">Usuari</rdfs:label>
  </owl:Class>
