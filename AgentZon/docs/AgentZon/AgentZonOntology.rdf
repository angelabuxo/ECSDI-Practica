<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:azon="http://www.semanticweb.org/agentzon#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/agentzon">
    <rdfs:label xml:lang="ca">Ontologia AgentZon</rdfs:label>
    <rdfs:comment xml:lang="ca">
      Ontologia compartida del sistema AgentZon. Modela actors, agents interns,
      productes, comandes, logística, devolucions, pagaments, suggeriments i les
      comunicacions RDF/FIPA-ACL que connecten tot el sistema distribuït.
    </rdfs:comment>
  </owl:Ontology>

  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Actor">
    <rdfs:label xml:lang="ca">Actor</rdfs:label>
    <rdfs:comment xml:lang="ca">Entitat que participa en el sistema, humana, externa o software.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#AgentIntern">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Actor"/>
    <rdfs:label xml:lang="ca">Agent intern</rdfs:label>
    <rdfs:comment xml:lang="ca">Agent desplegat per AgentZon per coordinar processos interns.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Usuari">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Actor"/>
    <rdfs:label xml:lang="ca">Usuari</rdfs:label>
    <rdfs:comment xml:lang="ca">Client final que cerca, compra, retorna i rep suggeriments.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#VenedorExtern">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Actor"/>
    <rdfs:label xml:lang="ca">Venedor extern</rdfs:label>
    <rdfs:comment xml:lang="ca">Tercer que publica productes i pot assumir la logística externa.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Transportista">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Actor"/>
    <rdfs:label xml:lang="ca">Transportista</rdfs:label>
    <rdfs:comment xml:lang="ca">Actor extern que envia ofertes i lliura lots de productes.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Banc">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Actor"/>
    <rdfs:label xml:lang="ca">Banc</rdfs:label>
    <rdfs:comment xml:lang="ca">Proveïdor extern responsable de l’autorització i liquidació dels pagaments.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#AgentCercador">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#AgentIntern"/>
    <rdfs:label xml:lang="ca">Agent Cercador</rdfs:label>
    <rdfs:comment xml:lang="ca">Agent que gestiona les restriccions de cerca i presenta resultats.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#AgentCompra">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#AgentIntern"/>
    <rdfs:label xml:lang="ca">Agent Compra</rdfs:label>
    <rdfs:comment xml:lang="ca">Agent que coordina el flux de compra i la informació d’enviament.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#AgentCentreLogistic">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#AgentIntern"/>
    <rdfs:label xml:lang="ca">Agent Centre Logístic</rdfs:label>
    <rdfs:comment xml:lang="ca">Agent que agrupa productes en lots i negocia el transport.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#AgentOpinador">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#AgentIntern"/>
    <rdfs:label xml:lang="ca">Agent Opinador</rdfs:label>
    <rdfs:comment xml:lang="ca">Agent que registra l’historial de compra i pot iniciar fluxos de feedback.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#AgentCobrador">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#AgentIntern"/>
    <rdfs:label xml:lang="ca">Agent Cobrador</rdfs:label>
    <rdfs:comment xml:lang="ca">Agent que coordina el pagament, la factura i les transferències externes.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#AgentRetornador">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#AgentIntern"/>
    <rdfs:label xml:lang="ca">Agent Retornador</rdfs:label>
    <rdfs:comment xml:lang="ca">Agent que avalua devolucions i coordina la recollida i el reemborsament.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#AgentVenedorExtern">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#AgentIntern"/>
    <rdfs:label xml:lang="ca">Agent Venedor Extern</rdfs:label>
    <rdfs:comment xml:lang="ca">Agent responsable de la integració de productes de tercers.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Producte">
    <rdfs:label xml:lang="ca">Producte</rdfs:label>
    <rdfs:comment xml:lang="ca">Producte publicat al catàleg i susceptible de cerca, compra o recomanació.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ProducteExtern">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Producte"/>
    <rdfs:label xml:lang="ca">Producte extern</rdfs:label>
    <rdfs:comment xml:lang="ca">Producte proporcionat per un venedor extern.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Comanda">
    <rdfs:label xml:lang="ca">Comanda</rdfs:label>
    <rdfs:comment xml:lang="ca">Unitat de compra confirmada per un usuari.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Lot">
    <rdfs:label xml:lang="ca">Lot</rdfs:label>
    <rdfs:comment xml:lang="ca">Agrupació logística de productes per negociar-ne l’enviament.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#CentreLogistic">
    <rdfs:label xml:lang="ca">Centre logístic</rdfs:label>
    <rdfs:comment xml:lang="ca">Ubicació física o virtual on es preparen comandes i lots.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#DadesEnviamentUsuari">
    <rdfs:label xml:lang="ca">Dades d’enviament d’usuari</rdfs:label>
    <rdfs:comment xml:lang="ca">Informació d’adreça, prioritat i preferències de lliurament.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#DadesBancaries">
    <rdfs:label xml:lang="ca">Dades bancàries</rdfs:label>
    <rdfs:comment xml:lang="ca">Informació bancària o de pagament associada a un actor o a una operació.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#HistorialCompra">
    <rdfs:label xml:lang="ca">Historial de compra</rdfs:label>
    <rdfs:comment xml:lang="ca">Registre de les comandes finalitzades per un usuari.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#HistorialCerca">
    <rdfs:label xml:lang="ca">Historial de cerca</rdfs:label>
    <rdfs:comment xml:lang="ca">Registre de consultes i restriccions utilitzades per l’usuari.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#UbicacioProducte">
    <rdfs:label xml:lang="ca">Ubicació de producte</rdfs:label>
    <rdfs:comment xml:lang="ca">Relació entre un producte i el centre logístic on es troba.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Devolucio">
    <rdfs:label xml:lang="ca">Devolució</rdfs:label>
    <rdfs:comment xml:lang="ca">Procés de retorn d’un producte i possible reemborsament.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Feedback">
    <rdfs:label xml:lang="ca">Feedback</rdfs:label>
    <rdfs:comment xml:lang="ca">Valoració o opinió d’un usuari després d’una compra.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Recomanacio">
    <rdfs:label xml:lang="ca">Recomanació</rdfs:label>
    <rdfs:comment xml:lang="ca">Conjunt de suggeriments personalitzats per a un usuari.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Pagament">
    <rdfs:label xml:lang="ca">Pagament</rdfs:label>
    <rdfs:comment xml:lang="ca">Operació de cobrament associada a una comanda o devolució.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Comunicacio">
    <rdfs:label xml:lang="ca">Comunicació</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge semàntic intercanviat entre actors i agents del sistema.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Accio">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Comunicacio"/>
    <rdfs:label xml:lang="ca">Acció</rdfs:label>
    <rdfs:comment xml:lang="ca">Comunicació que inicia un procés o demana una operació a un altre agent.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#Resposta">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Comunicacio"/>
    <rdfs:label xml:lang="ca">Resposta</rdfs:label>
    <rdfs:comment xml:lang="ca">Comunicació que informa del resultat d’una acció prèvia.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioCerca">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Petició de cerca</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge amb restriccions de text, categoria, marca i rang de preus.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ResultatCerca">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
    <rdfs:label xml:lang="ca">Resultat de cerca</rdfs:label>
    <rdfs:comment xml:lang="ca">Resposta que retorna els productes compatibles amb una petició de cerca.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioCompra">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Petició de compra</rdfs:label>
    <rdfs:comment xml:lang="ca">Inici del flux de compra per una selecció de productes.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioRegistreCompra">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Petició de registre de compra</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge que demana registrar una compra en l’historial.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ConfirmacioRegistreCompra">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
    <rdfs:label xml:lang="ca">Confirmació de registre de compra</rdfs:label>
    <rdfs:comment xml:lang="ca">Resposta que confirma que una compra ha estat persistida.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ProducteLocalitzat">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Producte localitzat</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge que trasllada al centre logístic els productes a preparar per a l’enviament.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioTransport">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Petició de transport</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge enviat a transportistes per demanar ofertes sobre un lot.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#RespostaOfertaTransport">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
    <rdfs:label xml:lang="ca">Resposta d’oferta de transport</rdfs:label>
    <rdfs:comment xml:lang="ca">Resposta amb cost, data prevista i identificació del transportista.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioPagament">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Petició de pagament</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge que activa l’autorització o captura del cobrament.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ConfirmacioPagament">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
    <rdfs:label xml:lang="ca">Confirmació de pagament</rdfs:label>
    <rdfs:comment xml:lang="ca">Resposta que confirma o rebutja un cobrament.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioDevolucio">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Petició de devolució</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge que inicia el flux de retorn d’un producte comprat.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ResolucioDevolucio">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
    <rdfs:label xml:lang="ca">Resolució de devolució</rdfs:label>
    <rdfs:comment xml:lang="ca">Resposta que accepta o rebutja una devolució i en descriu l’estat.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioFeedback">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Petició de feedback</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge que sol·licita una valoració a l’usuari després d’una compra.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#RespostaFeedback">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
    <rdfs:label xml:lang="ca">Resposta de feedback</rdfs:label>
    <rdfs:comment xml:lang="ca">Resposta que encapsula l’opinió o valoració aportada per l’usuari.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#PeticioRecomanacio">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Petició de recomanació</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge que demana generar suggeriments per a un usuari.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#RespostaRecomanacio">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
    <rdfs:label xml:lang="ca">Resposta de recomanació</rdfs:label>
    <rdfs:comment xml:lang="ca">Resposta que retorna una llista de suggeriments personalitzats.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#AltaProducteExtern">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">Alta de producte extern</rdfs:label>
    <rdfs:comment xml:lang="ca">Missatge que introdueix un nou producte d’un venedor extern.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://www.semanticweb.org/agentzon#ConfirmacioAltaProducteExtern">
    <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
    <rdfs:label xml:lang="ca">Confirmació d’alta de producte extern</rdfs:label>
    <rdfs:comment xml:lang="ca">Resposta que confirma la integració d’un producte extern al sistema.</rdfs:comment>
  </owl:Class>

  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#mostraProducte">
    <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#ResultatCerca"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Producte"/>
    <rdfs:label xml:lang="ca">mostra producte</rdfs:label>
    <rdfs:comment xml:lang="ca">Relaciona un resultat de cerca amb els productes retornats.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#teProducte">
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Producte"/>
    <rdfs:label xml:lang="ca">té producte</rdfs:label>
    <rdfs:comment xml:lang="ca">Relaciona una comanda, un lot o una comunicació amb els seus productes.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#teDadesEnviament">
    <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#Comanda"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#DadesEnviamentUsuari"/>
    <rdfs:label xml:lang="ca">té dades d’enviament</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#teDadesBancaries">
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#DadesBancaries"/>
    <rdfs:label xml:lang="ca">té dades bancàries</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#sobreComanda">
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Comanda"/>
    <rdfs:label xml:lang="ca">sobre comanda</rdfs:label>
    <rdfs:comment xml:lang="ca">Relaciona una comunicació amb la comanda sobre la qual opera.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#sobreLot">
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Lot"/>
    <rdfs:label xml:lang="ca">sobre lot</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#sobreProducte">
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Producte"/>
    <rdfs:label xml:lang="ca">sobre producte</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#ubicatACentre">
    <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#UbicacioProducte"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#CentreLogistic"/>
    <rdfs:label xml:lang="ca">ubicat a centre</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#assignatATransportista">
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Transportista"/>
    <rdfs:label xml:lang="ca">assignat a transportista</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#emissor">
    <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#Comunicacio"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Actor"/>
    <rdfs:label xml:lang="ca">emissor</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#receptor">
    <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#Comunicacio"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Actor"/>
    <rdfs:label xml:lang="ca">receptor</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#esRespostaA">
    <rdfs:domain rdf:resource="http://www.semanticweb.org/agentzon#Resposta"/>
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Accio"/>
    <rdfs:label xml:lang="ca">és resposta a</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#teFeedback">
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Feedback"/>
    <rdfs:label xml:lang="ca">té feedback</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.semanticweb.org/agentzon#generaRecomanacio">
    <rdfs:range rdf:resource="http://www.semanticweb.org/agentzon#Recomanacio"/>
    <rdfs:label xml:lang="ca">genera recomanació</rdfs:label>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#idProducte">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ca">IdProducte</rdfs:label>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#idComanda">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ca">IdComanda</rdfs:label>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/agentzon#idUsuari">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="ca">IdUsuari</rdfs:label>
