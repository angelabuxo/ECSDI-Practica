# Copia aquest fitxer a `distributed.env` i omple la IP del Directory.
#   cp distributed.env.example distributed.env
#
# El mateix fitxer es pot copiar a totes les màquines: cada PC detecta la seva
# IP local automàticament en executar ./run_distributed_agent.sh <agent>.
#
# Opcional: LOCAL_HOST=<ip> si la detecció automàtica falla (VPN, Wi‑Fi, etc.).

DIRECTORY_HOST=10.10.43.1
DIRECTORY_PORT=9000

# LOCAL_HOST=10.10.43.99

# Només per deploy_distributed.sh (SSH centralitzat):
# SSH_USER=student
# REMOTE_AGENTZON_DIR=/home/student/ECSDI-Practica/AgentZon
# DEPLOY_HOSTS_FILE=./deploy.hosts
